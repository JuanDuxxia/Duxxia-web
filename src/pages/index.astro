---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duxxia | Arquitectura de IA y Crecimiento B2B</title>
    <meta name="description" content="Duxxia: Ingeniería web, Agentes de IA y Growth Marketing para escalar operaciones empresariales." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-duxxia-midnight text-duxxia-silver font-inter antialiased selection:bg-duxxia-cyan selection:text-duxxia-midnight overflow-x-hidden">
    
    <nav class="fixed w-full z-50 bg-duxxia-midnight/60 backdrop-blur-xl border-b border-white/5">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="flex items-center p-2 px-3 rounded-xl bg-white/5 backdrop-blur-md border border-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)] hover:bg-white/15 transition-all group">
          <img src="/logo.png" alt="Duxxia Logo" class="h-8 md:h-10 transition-transform group-hover:scale-105 drop-shadow-md" />
        </a>
        
        <div class="hidden md:flex space-x-8 text-sm font-medium uppercase tracking-widest">
          <a href="#servicios" class="hover:text-duxxia-cyan transition-colors">Infraestructura</a>
          <a href="#ia" class="hover:text-duxxia-purple transition-colors">Agentes IA</a>
          <a href="#growth" class="hover:text-duxxia-cyan transition-colors">Growth</a>
        </div>
        
        <a href="#contacto" class="px-6 py-2.5 text-sm font-bold text-white bg-gradient-to-r from-duxxia-blue to-duxxia-purple rounded-full transition-all shadow-[0_0_20px_rgba(0,102,255,0.3)] hover:shadow-[0_0_30px_rgba(0,102,255,0.5)] hover:scale-105 active:scale-95">
          Auditoría Técnica
        </a>
      </div>
    </nav>

    <section class="relative pt-32 pb-20 lg:pt-52 lg:pb-40 overflow-hidden">
      <canvas id="particles-canvas" class="absolute inset-0 -z-10 opacity-60"></canvas>
      
      <div class="max-w-7xl mx-auto px-6 text-center relative">
        <div class="inline-flex items-center px-4 py-1.5 mb-8 rounded-full bg-duxxia-graphite/50 border border-white/10 text-[10px] font-bold uppercase tracking-[0.2em] text-duxxia-cyan backdrop-blur-sm reveal">
          <span class="w-2 h-2 rounded-full bg-duxxia-cyan mr-2 shadow-[0_0_8px_#00D4FF] animate-pulse"></span>
          Engineered for Performance
        </div>
        
        <h1 class="font-space text-5xl lg:text-8xl font-bold text-white tracking-tighter mb-8 leading-[0.95] reveal" style="transition-delay: 100ms;">
          Diseñamos el <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-duxxia-blue via-duxxia-cyan to-duxxia-purple">
            Ecosistema B2B
          </span>
        </h1>
        
        <p class="max-w-2xl mx-auto text-lg md:text-xl text-duxxia-silver/70 mb-12 leading-relaxed reveal" style="transition-delay: 200ms;">
          Arquitecturas de código, agentes inteligentes y estrategias de Growth Marketing integradas en un solo flujo operativo.
        </p>

        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4 mb-16 reveal" style="transition-delay: 300ms;">
          <div class="p-8 rounded-3xl bg-duxxia-graphite/60 border border-white/5 backdrop-blur-md flex items-center gap-6 group hover:border-duxxia-blue/30 transition-all shadow-xl">
            <div class="w-14 h-14 rounded-2xl bg-duxxia-blue/20 flex items-center justify-center text-duxxia-blue group-hover:rotate-12 transition-transform">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div class="text-left">
              <p class="text-[10px] font-bold text-duxxia-silver/40 uppercase tracking-widest">Optimización</p>
              <p class="font-space text-4xl font-bold text-white">320h<span class="text-lg text-duxxia-blue">/mes</span></p>
            </div>
          </div>
          
          <div class="p-8 rounded-3xl bg-duxxia-midnight/80 backdrop-blur-md border border-duxxia-blue/20 shadow-[0_0_40px_rgba(0,102,255,0.1)] flex flex-col justify-center items-center group overflow-hidden relative">
             <div class="absolute inset-0 bg-gradient-to-br from-duxxia-blue/5 to-transparent"></div>
             <p class="text-duxxia-cyan font-space text-5xl font-bold mb-1 relative group-hover:scale-110 transition-transform">+48%</p>
             <p class="text-[10px] font-bold text-duxxia-silver uppercase tracking-[0.3em] relative">Eficiencia Operativa</p>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row justify-center gap-6 reveal" style="transition-delay: 400ms;">
          <button class="px-10 py-4 bg-gradient-to-r from-duxxia-blue to-duxxia-purple text-white font-bold rounded-xl transition-all shadow-xl hover:shadow-duxxia-blue/40 hover:-translate-y-1">
            Consultoría Gratis
          </button>
          <button class="px-10 py-4 bg-white/5 text-white border border-white/10 hover:bg-white/10 rounded-xl transition-all backdrop-blur-sm">
            Nuestra Tecnología
          </button>
        </div>
      </div>
    </section>

    <section id="servicios" class="py-32 bg-duxxia-midnight relative border-t border-white/5">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-left mb-20 reveal">
          <h2 class="font-space text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">Capacidades <br/><span class="text-duxxia-cyan">Técnicas</span></h2>
          <div class="w-20 h-1 bg-duxxia-cyan"></div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="group p-10 rounded-[2.5rem] bg-duxxia-graphite/40 border border-white/5 hover:border-duxxia-cyan/40 transition-all hover:bg-duxxia-graphite/60 reveal backdrop-blur-sm shadow-lg">
            <div class="text-duxxia-cyan mb-8 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
            </div>
            <h3 class="font-space text-xl font-bold text-white mb-4">Web Core</h3>
            <p class="text-sm text-duxxia-silver/60 leading-relaxed">Infraestructura escalable con Astro, React y Node.js. Velocidad y seguridad por diseño.</p>
          </div>
          <div id="ia" class="group p-10 rounded-[2.5rem] bg-duxxia-graphite/40 border border-white/5 hover:border-duxxia-purple/40 transition-all hover:bg-duxxia-graphite/60 reveal backdrop-blur-sm shadow-lg">
            <div class="text-duxxia-purple mb-8 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-space text-xl font-bold text-white mb-4">AI Agents</h3>
            <p class="text-sm text-duxxia-silver/60 leading-relaxed">Sistemas RAG integrados que procesan tu base de conocimiento para automatizar respuestas.</p>
          </div>
          <div class="group p-10 rounded-[2.5rem] bg-duxxia-graphite/40 border border-white/5 hover:border-duxxia-cyan/40 transition-all hover:bg-duxxia-graphite/60 reveal backdrop-blur-sm shadow-lg">
            <div class="text-duxxia-cyan mb-8 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
            </div>
            <h3 class="font-space text-xl font-bold text-white mb-4">Ecosystems</h3>
            <p class="text-sm text-duxxia-silver/60 leading-relaxed">Conexiones API fluidas entre Landing, CRM, WhatsApp y Analytics para control total.</p>
          </div>
          <div id="growth" class="group p-10 rounded-[2.5rem] bg-duxxia-graphite/40 border border-white/5 hover:border-duxxia-purple/40 transition-all hover:bg-duxxia-graphite/60 reveal backdrop-blur-sm shadow-lg">
            <div class="text-duxxia-purple mb-8 group-hover:scale-110 transition-transform">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h3 class="font-space text-xl font-bold text-white mb-4">Growth B2B</h3>
            <p class="text-sm text-duxxia-silver/60 leading-relaxed">Estrategias de adquisición basadas en datos y CPA optimizado para leads de alta calidad.</p>
          </div>
        </div>
      </div>
    </section>

    <footer class="py-20 bg-duxxia-midnight border-t border-white/5 text-center">
      <img src="/logo.png" alt="Duxxia" class="h-10 mx-auto mb-8 opacity-30 grayscale" />
      <p class="text-[10px] text-duxxia-silver/40 uppercase tracking-[0.5em] font-bold">
        &copy; 2026 DUXXIA S.A.S. | BEYOND INTELLIGENCE
      </p>
    </footer>

    <script>
      // 1. ANIMACIÓN DE APARICIÓN (Scroll Observer)
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = "1";
            entry.target.style.transform = "translateY(0)";
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach((el) => {
        el.style.opacity = "0";
        el.style.transform = "translateY(30px)";
        el.style.transition = "all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1)";
        observer.observe(el);
      });

      // 2. RED NEURONAL (Canvas Particles)
      const canvas = document.getElementById('particles-canvas');
      if (canvas) {
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resize() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();

        class Particle {
          constructor() {
            this.init();
          }
          init() {
            this.x = Math.random() * canvas.width;
            this.y = Math.random() * canvas.height;
            this.vx = (Math.random() - 0.5) * 0.6; // Velocidad
            this.vy = (Math.random() - 0.5) * 0.6;
          }
          update() {
            this.x += this.vx;
            this.y += this.vy;
            if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
            if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
          }
        }

        // Crear partículas
        for (let i = 0; i < 90; i++) particles.push(new Particle());

        function draw() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.lineWidth = 0.6;
          for (let i = 0; i < particles.length; i++) {
            let p1 = particles[i];
            p1.update();
            for (let j = i + 1; j < particles.length; j++) {
              let p2 = particles[j];
              let dist = Math.hypot(p1.x - p2.x, p1.y - p2.y);
              // Si están cerca, dibujamos una línea
              if (dist < 160) {
                // Color corporativo (Purple/Cyan mix) con opacidad basada en la distancia
                ctx.strokeStyle = `rgba(0, 212, 255, ${0.8 - dist/160})`;
                ctx.beginPath();
                ctx.moveTo(p1.x, p1.y);
                ctx.lineTo(p2.x, p2.y);
                ctx.stroke();
              }
            }
          }
          requestAnimationFrame(draw);
        }
        draw();
      }
    </script>
  </body>
</html>